# --- Baalda · sync + app server ---

# Postgres. docker-compose maps host 5439 -> container 5432.
DATABASE_URL=postgres://context:context@localhost:5439/context

# Better Auth session/crypto secret. Generate with: openssl rand -base64 32
JWT_SECRET=dev-only-insecure-change-me-please-32bytes

# Public base URL Better Auth uses to build links (email verify / invitations).
BETTER_AUTH_URL=http://localhost:3010

# HTTP API port (Better Auth, sync-token, shares, registry). Hono app.
PORT=3010

# Hocuspocus WebSocket port. Kept separate from the HTTP port for clarity;
# both processes share one Node process. See README "Ports".
# The same Hocuspocus instance is ALSO served on the HTTP PORT at path /sync —
# single-port deployments (Docker/Railway, which expose exactly one port) use
# that instead of this dedicated port.
HOCUSPOCUS_PORT=3011

# Per-doc sync JWT TTL (seconds). Spec: 5-15 min. Default 10 min.
SYNC_TOKEN_TTL_SECONDS=600

# Compaction threshold: merge doc_updates into a snapshot when the log exceeds this.
COMPACTION_THRESHOLD=50
