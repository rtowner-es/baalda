{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:wait": "node scripts/wait-for-db.mjs",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hocuspocus/server": "^4.4.0",
    "@hono/node-server": "^1.19.9",
    "@node-rs/argon2": "^2.0.2",
    "better-auth": "^1.6.23",
    "dotenv": "^17.2.3",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "kysely": "^0.29.3",
    "pg": "^8.22.0",
    "ws": "^8.21.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^4.4.0",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "vitest": "^4.1.10",
    "y-protocols": "^1.0.7"
  }
}
